# ── Gmail (問い合わせメール送信) ───────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_TO=
GOLF_DTV_TO=

# ── Google Tag Manager ────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=

# ── Google Sheets Webhook (任意) ──────────────────────────────────────────────
GOOGLE_SHEETS_WEBHOOK_URL=

# ── Meta Conversions API (CAPI) ───────────────────────────────────────────────
# Pixel ID (公開情報 — NEXT_PUBLIC_ 可)
META_PIXEL_ID=
# システムユーザーアクセストークン (秘密情報 — サーバー専用・絶対に NEXT_PUBLIC_ にしない)
META_CAPI_ACCESS_TOKEN=
# テストイベントコード (任意: Meta Events Manager のテストタブで取得。本番では未設定にする)
META_CAPI_TEST_EVENT_CODE=
